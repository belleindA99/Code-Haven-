## lib.rs

```rust
#![no_std]
use soroban_sdk::{contract, contractimpl, Env, Address, Vec};

#[contract]
pub struct MeowdoroGroup;

#[contractimpl]
impl MeowdoroGroup {

    pub fn deposit(env: Env, user: Address, amount: i128) {
        user.require_auth();
        let mut users: Vec<Address> = env.storage().instance().get(&"users").unwrap_or(Vec::new(&env));
        users.push_back(user);
        env.storage().instance().set(&"users", &users);
        env.storage().instance().set(&( "bal", users.len() ), &amount);
    }

    pub fn complete(env: Env, user: Address) {
        user.require_auth();
        env.storage().instance().set(&( "done", user ), &true);
    }

    pub fn distribute(env: Env) -> i128 {
        let users: Vec<Address> = env.storage().instance().get(&"users").unwrap();
        let mut total: i128 = 0;
        let mut winners: i128 = 0;

        for i in 0..users.len() {
            let u = users.get(i).unwrap();
            let done: bool = env.storage().instance().get(&( "done", u.clone() )).unwrap_or(false);
            let bal: i128 = env.storage().instance().get(&( "bal", i )).unwrap_or(0);

            total += bal;

            if done {
                winners += 1;
            }
        }

        if winners == 0 {
            panic!("No winners");
        }

        total / winners
    }
}
```

