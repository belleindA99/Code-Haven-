### lib.rs

```rust
#![no_std]
use soroban_sdk::{contract, contractimpl, symbol_short, Env, Address, Symbol};

#[contract]
pub struct MeowdoroPay;

const BALANCE: Symbol = symbol_short!("BAL");
const TIMER_DONE: Symbol = symbol_short!("DONE");

#[contractimpl]
impl MeowdoroPay {

    // User stakes XLM (simulated as stored balance)
    pub fn stake(env: Env, user: Address, amount: i128) {
        user.require_auth();

        env.storage().instance().set(&(BALANCE, user.clone()), &amount);
        env.storage().instance().set(&(TIMER_DONE, user.clone()), &false);
    }

    // Mark Pomodoro complete
    pub fn complete(env: Env, user: Address) {
        user.require_auth();

        env.storage().instance().set(&(TIMER_DONE, user.clone()), &true);
    }

    // Claim reward if completed
    pub fn claim(env: Env, user: Address) -> i128 {
        user.require_auth();

        let done: bool = env.storage().instance().get(&(TIMER_DONE, user.clone())).unwrap();

        if !done {
            panic!("Session not completed");
        }

        let balance: i128 = env.storage().instance().get(&(BALANCE, user.clone())).unwrap();

        let reward = balance + (balance / 10); // +10%

        reward
    }
}
```

